{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "src/api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/",
      "dest": "src/api/index.ts"
    },
    {
      "src": "/",
      "status": 308,
      "headers": {
        "Location": "https://github.com/S1l3ntStr1ke87/gitlab-readme-stats"
      }
    }
  ]
}